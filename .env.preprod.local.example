# ==============================================================================
# Production secrets — copy this file to .env.preprod.local and fill values
# This file is tracked in git (no secrets). .env.preprod.local is gitignored.
# ==============================================================================

# ==============================================================================
# ISR & CACHE REVALIDATION
# ==============================================================================
# Global fallback token for on-demand revalidation API (/api/revalidate)
# Generate a strong random token: openssl rand -base64 32
# Journal-specific tokens can be set via REVALIDATION_TOKEN_<JOURNAL_CODE>
REVALIDATION_SECRET=""

# ==============================================================================
# VALKEY / REDIS DISTRIBUTED CACHE
# ==============================================================================

# Enable distributed cache (false for local dev, true in production)
VALKEY_ENABLED=false

# Sentinel hosts (comma-separated host:port)
VALKEY_SENTINEL_HOSTS="sentinel-1:26379,sentinel-2:26379,sentinel-3:26379"

# Sentinel master group name
VALKEY_MASTER_NAME=mymaster

# Valkey ACL username and password
VALKEY_USERNAME=""
VALKEY_PASSWORD=""

# Sentinel ACL username and password (can differ from node credentials)
VALKEY_SENTINEL_USERNAME=""
VALKEY_SENTINEL_PASSWORD=""

# Key prefix for Next.js cache entries
VALKEY_KEY_PREFIX="next:"

# Circuit breaker: errors before switching to in-memory fallback (default: 5)
VALKEY_CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker: seconds before probing Valkey recovery (default: 30)
VALKEY_CIRCUIT_BREAKER_PROBE_INTERVAL=30