NEXT_PUBLIC_EPISCIENCES_HOMEPAGE="https://www.episciences.org"
NEXT_PUBLIC_EPISCIENCES_HOMEPAGE_FR="https://www.episciences.org/fr/accueil"

NEXT_PUBLIC_EPISCIENCES_JOURNALS_PAGE="https://www.episciences.org/journals"
NEXT_PUBLIC_EPISCIENCES_JOURNALS_PAGE_FR="https://www.episciences.org/fr/revues"

NEXT_PUBLIC_EPISCIENCES_DOCUMENTATION_PAGE="https://doc.episciences.org"
NEXT_PUBLIC_EPISCIENCES_DOCUMENTATION_PAGE_FR="https://doc.episciences.org/fr"

NEXT_PUBLIC_EPISCIENCES_ACKNOWLEDGEMENTS_PAGE="https://www.episciences.org/partners"
NEXT_PUBLIC_EPISCIENCES_ACKNOWLEDGEMENTS_PAGE_FR="https://www.episciences.org/fr/partenaires"

NEXT_PUBLIC_EPISCIENCES_LEGAL_TERMS_PAGE="https://www.episciences.org/legal-terms"
NEXT_PUBLIC_EPISCIENCES_LEGAL_TERMS_PAGE_FR="https://www.episciences.org/fr/mentions-legales"

NEXT_PUBLIC_EPISCIENCES_LEGAL_PRIVACY_STATEMENT_PAGE="https://www.episciences.org/privacy-and-personal-data"
NEXT_PUBLIC_EPISCIENCES_LEGAL_PRIVACY_STATEMENT_PAGE_FR="https://www.episciences.org/fr/donnees-personnelles"

NEXT_PUBLIC_EPISCIENCES_LEGAL_PRIVACY_TERMS_OF_USE_PAGE="https://www.episciences.org/terms-of-use"
NEXT_PUBLIC_EPISCIENCES_LEGAL_PRIVACY_TERMS_OF_USE_PAGE_FR="https://www.episciences.org/fr/cgu"

# External service URLs
NEXT_PUBLIC_ORCID_HOMEPAGE="https://orcid.org"
NEXT_PUBLIC_DOI_HOMEPAGE="https://doi.org"
NEXT_PUBLIC_ZOTERO_HOMEPAGE="https://www.zotero.org"
NEXT_PUBLIC_ARXIV_HOMEPAGE="https://arxiv.org"
NEXT_PUBLIC_CREATIVE_COMMONS_HOMEPAGE="https://creativecommons.org"
NEXT_PUBLIC_ARCHIVE_SOFTWARE_HERITAGE_HOMEPAGE="https://archive.softwareheritage.org"
NEXT_PUBLIC_HAL_HOMEPAGE="https://hal.science"

# CDN URLs
NEXT_PUBLIC_MATHJAX_HOMEPAGE="https://cdnjs.cloudflare.com/ajax/libs/mathjax"

# Social media URLs
NEXT_PUBLIC_TWITTER_HOMEPAGE="https://x.com"

# Email configuration
NEXT_PUBLIC_EMAILS_SUFFIX="@episciences.org"

# Analytics
NEXT_PUBLIC_MATOMO_DOMAIN="https://piwik-episciences.ccsd.cnrs.fr/"

# ==============================================================================
# ISR & CACHE REVALIDATION
# ==============================================================================
# Global fallback token for on-demand revalidation API (/api/revalidate)
# Generate a strong random token: openssl rand -base64 32
# Journal-specific tokens can be set via REVALIDATION_TOKEN_<JOURNAL_CODE>
# Override in .env.production.local (never commit secrets)
REVALIDATION_SECRET=""

# ==============================================================================
# VALKEY / REDIS DISTRIBUTED CACHE
# ==============================================================================
# Shared infrastructure config — identical for all journals in a given environment.
# Override per environment in .env.production.local or .env.development.local
# (those files are gitignored and never committed).

# Enable distributed cache (false for local dev, true in production)
VALKEY_ENABLED=false

# Sentinel hosts (comma-separated host:port)
VALKEY_SENTINEL_HOSTS="sentinel-1:26379,sentinel-2:26379,sentinel-3:26379"

# Sentinel master group name
VALKEY_MASTER_NAME=mymaster

# Valkey authentication password (leave empty for local dev)
VALKEY_PASSWORD=""

# Sentinel password (can be different from node password)
VALKEY_SENTINEL_PASSWORD=""

# Key prefix for Next.js cache entries
VALKEY_KEY_PREFIX="next:"

# Circuit breaker: errors before switching to in-memory fallback (default: 5)
VALKEY_CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker: seconds before probing Valkey recovery (default: 30)
VALKEY_CIRCUIT_BREAKER_PROBE_INTERVAL=30