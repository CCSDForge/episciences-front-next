# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==========================================
# System & IDEs
# ==========================================
.DS_Store
Thumbs.db
/.idea/
/.vscode/

# ==========================================
# Dependencies
# ==========================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==========================================
# Build & Compilation Outputs
# ==========================================
/.next/
/out/
/build
/dist/
*.tsbuildinfo
next-env.d.ts

# ==========================================
# Environment & Secrets
# ==========================================
.env*
!.env
!.env.production.local.example
!.env.preprod.local.example
*.pem

# ==========================================
# Logs, Debug & Temporary files
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
build.log
/logs/
/tmp/

# ==========================================
# Testing & Coverage
# ==========================================
/coverage
.vitest/

# ==========================================
# Deployment
# ==========================================
.vercel
/deployment/ansible/inventory/*.ini
/deployment/ansible/group_vars/**/secrets.yml
/deployment/ansible/roles/

# ==========================================
# Local AI & Dev Agent environments
# ==========================================
/.claude/
/.gemini/
/.agents/
/.playwright-mcp/

# ==========================================
# Journal-specific Assets & Generated Files
# ==========================================
/external-assets/
/public/robots.txt
/public/sitemap.xml
/public/logos/*.svg
!/public/logos/logo-episciences.svg
